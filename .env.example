APP_NAME=AssetSphere API
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/assetsphere

# JWT
JWT_ACCESS_SECRET=change-this-access-secret
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# 32-byte base64 encoded key for AES-256-GCM
CRYPTO_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTE_KEY
